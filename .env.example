# RFP Analyzer Environment Variables

# ==============================================================================
# Ingestion Layer (Phase 1)
# ==============================================================================
# Get this from https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY="your-llama-cloud-key"

# ==============================================================================
# Retrieval Layer (Phase 2)
# ==============================================================================
# Get this from https://app.pinecone.io/
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_ENVIRONMENT="gcp-starter" # or whatever environment your serverless index is in
PINECONE_INDEX_NAME="rfp-analyzer"

# ==============================================================================
# Reasoning Layer (Phase 3)
# ==============================================================================
# Get this from https://console.groq.com/keys
GROQ_API_KEY="your-groq-api-key"

# Get this from https://aistudio.google.com/app/apikey
# Used for embeddings and the Validation Agent
GEMINI_API_KEY="your-gemini-api-key"

# ==============================================================================
# Presentation Layer (Phase 4)
# ==============================================================================
# Keep this secure in production. For basic auth on upload.
UPLOAD_ACCESS_CODE="dev-access-code"
